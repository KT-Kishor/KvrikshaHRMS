<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">
    <Dialog
        contentWidth="800px"
        contentHeight="400px"
        resizable="true"
        draggable="true">
        <customHeader >
        <Bar class="Coursetitle" >
           <contentLeft>
              <Title  text="{i18n>monthlyinvoicefor} {MonthlyListPopoverData>/Month}"  />
        </contentLeft>
            <contentRight>
                <Button icon="sap-icon://decline" press="onCloseDialog" tooltip="Close"/>
            </contentRight>
        </Bar>
    </customHeader>
        <content>
            <Table
            sticky="ColumnHeaders"
                items="{MonthlyListPopoverData>/Records}"
                noDataText="{i18n>nomonthlydata}">
                <columns>
                  <Column demandPopin="true" hAlign="Left"><Text text="{i18n>invoiceNo}" /></Column>
                     <Column demandPopin="true" hAlign="Left" minScreenWidth="Desktop"><Text text="{i18n>creditMemoNo}" /></Column>
                    <Column demandPopin="true" hAlign="Left"><Text text="{i18n>invoiceDate}" /></Column>
                     <Column demandPopin="true" hAlign="Left" minScreenWidth="Tablet"><Text text="{i18n>customerName}" /></Column>
                    <Column demandPopin="true" hAlign="End"><Text text="{i18n>totalAmount}" /></Column>
                </columns>
                <items>
                    <ColumnListItem type="Navigation" press="onPendingInvoicePress">
                        <cells>
                            <Text text="{MonthlyListPopoverData>InvNo}" />
                            <Text text="{MonthlyListPopoverData>CCInvNo}" />
                            <Text text="{ path: 'MonthlyListPopoverData>InvoiceDate', formatter:'.Formatter.formatDate'}" />
                            <Text text="{MonthlyListPopoverData>CustomerName}" />
                            <VBox >
                            <ObjectNumber number="{parts: [ { path: 'MonthlyListPopoverData>TotalAmount' } ], formatter: '.Formatter.fromatNumber'}" unit="{MonthlyListPopoverData>Currency}" />
								<ObjectNumber visible="{= ${MonthlyListPopoverData>Currency} !== 'INR' }" number="{parts: [{ path: 'MonthlyListPopoverData>AmountInINR' }], formatter: '.Formatter.fromatNumber'}" unit="INR" />
							</VBox>
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
        </content>
       <footer>
			<Toolbar>
				<ToolbarSpacer/>
				<Text text="Total Amount : "/>
				<ObjectNumber 
						number="{parts: [{ path: 'MonthlyListPopoverData>/TotalAmount' }], formatter: '.Formatter.fromatNumber'}"
						unit="INR" />
        	</Toolbar>
		</footer>
    </Dialog>
</core:FragmentDefinition>