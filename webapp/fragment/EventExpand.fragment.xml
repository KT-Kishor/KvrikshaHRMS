<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:l="sap.ui.layout">

    <Dialog
        contentWidth="700px"
        contentHeight="700px"
        verticalScrolling="false"
        horizontalScrolling="false"
        class="customEventDialog">

        <!-- ================= HEADER ================= -->

        <customHeader>

            <Bar>

                <contentMiddle>

                    <Title
                        text="Event Details"/>

                </contentMiddle>

                <contentRight>

                    <Button
                        icon="sap-icon://exit-full-screen"
                        type="Transparent"
                        press="onCloseExpand"/>

                </contentRight>

            </Bar>

        </customHeader>

        <!-- ================= CONTENT ================= -->

        <content>

            <VBox class="eventDialogContainer">

                <!-- ================= IMAGE SECTION ================= -->

                <VBox class="dialogImageSection">

                    <Image
                        src="{= 'data:image/jpeg;base64,' + ${EventCardModel>File} }"
                        width="100%"
                        height="230px"
                        class="dialogImage"/>

                    <!-- Overlay -->
                    <VBox class="dialogOverlayContent">

                        <!-- Date -->
                        <Text
                            text="{
                                path: 'EventCardModel>StartDateTime',
                                formatter: '.formatCardDate'
                            }"
                            class="dateText sapUiTinyMarginBottom"/>

                        <!-- Title -->
                        <Title
                            text="{EventCardModel>EventName}"
                            level="H1"
                            wrapping="true"
                            class="dialogTitleText sapUiTinyMarginBottom" />

                        <!-- Status -->
                        <Text
                            text="{
                                path: 'EventCardModel>StartDateTime',
                                formatter: '.formatEventStatus'
                            }"
                            class="dialogSubTitleText"/>
                         <Text
                text="{EventCardModel>Address}"
                class="dialogSubTitleText"/>

                    </VBox>

                </VBox>

               <!-- ================= BODY ================= -->

<ScrollContainer
    height="420px"
    width="100%"
    vertical="true"
    horizontal="false"
    class="sapUiNoContentPadding">

       
        <!-- Description -->
        <HBox
            alignItems="Start"
            class="sapUiMediumMargin ">

            <Text
                text="{EventCardModel>Content}"
                wrapping="true"
                class="dialogDescription sapUiTinyMarginBegin"/>

        </HBox>

</ScrollContainer>

            </VBox>

        </content>
        <footer>

    <Toolbar class="dialogFooterToolbar">

        <ToolbarSpacer/>

        <Button
            text="Register Now"
            type="Emphasized"
            press="onRegisternow"   visible="{
        path: 'EventCardModel>StartDateTime',
        formatter: '.isUpcomingEvent'
    }">

            <customData>

                <core:CustomData
                    key="registerLink"
                    value="{EventCardModel>LinkToRegister}"/>

            </customData>

        </Button>

    </Toolbar>

</footer>

    </Dialog>

</core:FragmentDefinition>