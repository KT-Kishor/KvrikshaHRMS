<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">
    <Dialog id="TotalInvoicesvalueDialog" contentWidth="1000px" contentHeight="500px" resizable="true" draggable="true">
        <customHeader >
        <Bar class="Coursetitle"  >
        <contentLeft>
         <Title text="{i18n>totalInvoiceValue} {companyPopoverData>/CompanyName}"  />
         </contentLeft>
          
            <contentRight>
                <Button icon="sap-icon://decline" press="onCloseDialog" tooltip="Close"/>
            </contentRight>
        </Bar>
    </customHeader>
        <content>
            <Table
            sticky="ColumnHeaders"
                items="{companyPopoverData>/Records}"
                noDataText="{i18n>noPendingData}">
                <columns>
                   <Column demandPopin="true" hAlign="Left"><Text text="{i18n>invoice_No}" tooltip="{i18n>invoiceNo}" /></Column>
                    <Column demandPopin="true" hAlign="Left"><Text text="{i18n>invoice_Date}" tooltip="{i18n>invoiceDate}" /></Column>
                    <Column demandPopin="true" hAlign="Left" minScreenWidth="Desktop"><Text text="{i18n>customer_Name}" tooltip="{i18n>transactionAmount}" /></Column>
                    <Column demandPopin="true" hAlign="End"><Text text="{i18n>credit_Notes_Amount}" tooltip="{i18n>creditNotesAmount}" /></Column>
                    <!-- <Column hAlign="End" demandPopin="true" minScreenWidth="Desktop"><Text text="{i18n>exchRate}" tooltip="{i18n>exchRate}"/></Column> -->
                    <Column hAlign="End" demandPopin="true" minScreenWidth="Desktop"><Text text="{i18n>total_Amount}" tooltip="{i18n>totalAmount}" /></Column>
                    <Column demandPopin="true" hAlign="Left"><Text text="{i18n>status}" tooltip="{i18n>status}"/></Column>
                    <Column hAlign="End" demandPopin="true" minScreenWidth="Desktop"><Text text="{i18n>actual_Amount}" tooltip="{i18n>Actual Amount}" /></Column>
                </columns>
                <items>
                    <ColumnListItem type="Navigation" press="onPressInvoiceDetails">
                        <cells>
                            <Text text="{companyPopoverData>InvNo}" />
                             <Text text="{path: 'companyPopoverData>InvoiceDate', formatter:'.Formatter.formatDate'}" />
                            <ObjectNumber number="{parts: [{ path: 'companyPopoverData>TransactionAmount' }], formatter: '.Formatter.fromatNumber'}" unit="{companyPopoverData>Currency}" />
                            <VBox >
                                <Link wrapping="true" class="creditLinkStyle" press="onTotalVoicePaymentAmountPress" text="{parts: [{ path: 'companyPopoverData>CreditNotesTotalAmount' },{ path: 'companyPopoverData>Currency' }],formatter: '.Formatter.formatAmountWithCurrency'}"/>
								<Link wrapping="true" visible="{= ${companyPopoverData>Currency} !== 'INR' }" class="creditLinkStyle" press="onTotalVoicePaymentAmountPress" text="{parts: [{ path: 'companyPopoverData>CreditNotesAmount' },{ value: 'INR' }],formatter: '.Formatter.formatAmountWithCurrency'}"/>
							</VBox>
                            <VBox alignItems="End">
                                <ObjectNumber number="{parts: [{ path: 'companyPopoverData>Currency' },{ path: 'companyPopoverData>TotalAmount' },{ path: 'companyPopoverData>AmountInINR' }], formatter: '.Formatter.fromatNumber'}" unit="INR" />
                                <HBox visible="{= ${companyPopoverData>Currency} !== 'INR' }" justifyContent="End">
                                    <Text text="Exch. Rate: " />
                                    <ObjectIdentifier title="{path:'companyPopoverData>ExchRate', formatter: '.Formatter.fromatNumber'}"/>
                                </HBox>
                            </VBox>
                            <Text text="{companyPopoverData>Status}" />
                            <Link id="idTotalVoice" press="onPressActualAmount" wrapping="true" class="creditLinkStyle"  text="{
                                    parts: [
                                        { path: 'companyPopoverData>AllTotalAndActualAmount' },
                                        { value: 'INR' }
                                    ],
                                    formatter: '.Formatter.paymentOrActualAmount'
                                }"/>
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
        </content>
        <footer>
			<Toolbar>
				<ToolbarSpacer/>
				<Text text="Total Amount : "/>
				<ObjectNumber number="{parts: [{ path: 'companyPopoverData>/TotalAmount' }], formatter: '.Formatter.fromatNumber'}" unit="INR" />
                        <!-- <ToolbarSpacer/> -->

				<Text text="Actual Amount : "/>
				<ObjectNumber number="{parts: [{ path: 'companyPopoverData>/AllActualAmount' }],formatter: '.Formatter.fromatNumber'}" unit="INR"/>
        	</Toolbar>
		</footer>
    </Dialog>
</core:FragmentDefinition>