<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">
    <Dialog
        id="pendingInvoicesDialog"
        contentWidth="1000px"
        contentHeight="500px"
        resizable="true"
        draggable="true">
          <customHeader >
        <Bar class="Coursetitle" >
        <contentLeft>
         <Title text="{i18n>pendingInvoicepayment} {PendingInvoicesData>/CompanyName}"/>
        </contentLeft>
           
            <contentRight>
                <Button icon="sap-icon://decline" press="onCloseDialog" tooltip="Close"/>
            </contentRight>
        </Bar>
    </customHeader>
        <content>
            <Table
            sticky="ColumnHeaders"
                items="{PendingInvoicesData>/Invoices}"
                noDataText="{i18n>noPendingData}">
                <columns>
                    <Column demandPopin="true" hAlign="Left"><Text text="{i18n>invoice_No}" tooltip="{i18n>invoiceNo}" /></Column>
                    <Column demandPopin="true" hAlign="Left"><Text text="{i18n>invoice_Date}" tooltip="{i18n>invoiceDate}" /></Column>
                    <!-- <Column demandPopin="true" hAlign="Left" minScreenWidth="Desktop"><Text text="{i18n>customerName}" /></Column> -->
                    <Column demandPopin="true" hAlign="Left" minScreenWidth="Desktop"><Text text="{i18n>transaction_Amount}" tooltip="{i18n>transactionAmount}" /></Column>
                    <Column demandPopin="true" hAlign="End"><Text text="{i18n>credit_Notes_Amount}" tooltip="{i18n>creditNotesAmount}" /></Column>
                    <Column demandPopin="true" hAlign="End"><Text text="{i18n>invoice_Received_Amount}" tooltip="{i18n>invoiceReceivedAmount}" /></Column>
                    <Column hAlign="End" demandPopin="true" minScreenWidth="Desktop"><Text text="{i18n>exchRate}" /></Column>
                    <Column hAlign="End" demandPopin="true" minScreenWidth="Desktop"><Text text="{i18n>pending_Amount_Inr}" tooltip="{i18n>pendingAmountInr}" /></Column>
                    <Column demandPopin="true" hAlign="Left"><Text text="{i18n>status}" /></Column>
                </columns>
                <items>
                    <ColumnListItem type="Navigation" press="onInvoicePressChart6">
                        <cells>
                            <Text text="{PendingInvoicesData>InvNo}" />

                            <Text text="{path: 'PendingInvoicesData>InvoiceDate',formatter:'.Formatter.formatDate'}" />

                            <ObjectNumber number="{parts: [{ path: 'PendingInvoicesData>TransactionAmount' }], formatter: '.Formatter.fromatNumber'}" unit="{PendingInvoicesData>Currency}" />

                            <VBox >
                                <Link wrapping="true" class="creditLinkStyle" press="onInvoiceCreditNotesPressPendingInvoices" text="{parts: [{ path: 'PendingInvoicesData>CreditNotesTotalAmount' },{ path: 'PendingInvoicesData>Currency' }],formatter: '.Formatter.formatAmountWithCurrency'}"/>
								<Link wrapping="true" visible="{= ${PendingInvoicesData>Currency} !== 'INR' }" class="creditLinkStyle" press="onInvoiceCreditNotesPressPendingInvoices" text="{parts: [{ path: 'PendingInvoicesData>CreditNotesAmount' },{ value: 'INR' }],formatter: '.Formatter.formatAmountWithCurrency'}"/>
							</VBox>
                            <ObjectNumber number="{path: 'PendingInvoicesData>InvoicePaymentTotalRecived',formatter: '.Formatter.fromatNumber'}" unit="INR" />
                            <ObjectIdentifier title="{path:'PendingInvoicesData>ExchRate', formatter: '.Formatter.fromatNumber'}"/>
                            <ObjectNumber number="{path: 'PendingInvoicesData>PendingAmount',formatter: '.Formatter.fromatNumber'}" unit="INR" />
                            <Text text="{PendingInvoicesData>Status}" />
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
        </content>
         <footer>
			<Toolbar>
				<ToolbarSpacer/>
				<Text text="Total Amount : "/>
				<ObjectNumber 
						number="{parts: [{ path: 'PendingInvoicesData>/AllTotalAmount' }], formatter: '.Formatter.fromatNumber'}"
						unit="INR" />
        	</Toolbar>
		</footer>
    </Dialog>
</core:FragmentDefinition>