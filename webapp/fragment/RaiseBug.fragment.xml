<c:FragmentDefinition
	xmlns="sap.m"
	xmlns:c="sap.ui.core"
	xmlns:f="sap.ui.layout.form"
	xmlns:core="sap.ui.core"
	xmlns:u="sap.ui.unified"
>
	<Dialog
		id="RG_id_Dialog"
		type="Message"
		class="sapUiContentPadding"
		contentWidth="28rem"
		resizable="true"
		draggable="true"
	>
		<customHeader>
			<Bar class="barheader">
				<contentMiddle>
					<Title text="Manage Bug" />
				</contentMiddle>
			</Bar>
		</customHeader>
		<f:SimpleForm
			editable="true"
			layout="ResponsiveGridLayout"
			labelSpanXL="4"
			labelSpanL="3"
			labelSpanM="4"
			labelSpanS="12"
			columnsXL="2"
			columnsL="2"
			columnsM="1"
		>
			<f:content>
				<!-- Issue Type -->
				<Label
					text="{i18n>appname}"
					required="{RaiseBugModel>/Submit}"
				/>
				<ComboBox
					editable="{VisibleModel>/Editable}"
					id="RB_id_appname"
					valueStateText="{i18n>enterappname}"
					placeholder="Select issue type"
					value="{RaiseBugModel>/AppName}"
					change="onAppnamechanges"
					items="{ApplicationName>/}"
				>
					<core:Item
						key="{ApplicationName>ID}"
						text="{ApplicationName>AppName}"
					/>
				</ComboBox>

					<Label
					text="{i18n>Type}"
					required="{RaiseBugModel>/Submit}"
				/>
				<ComboBox
					editable="{VisibleModel>/Editable}"
					id="RB_id_type"
					valueStateText="{i18n>entertype}"
					placeholder="Select Issue type"
					value="{RaiseBugModel>/IssueType}"
					change="ontypenamechanges"
				>
					<core:Item
						key="Bug"
						text="Bug"
					/>
							<core:Item
						key="New Feature"
						text="New Feature"
					/>
				</ComboBox>
				<!-- Issue Description -->
				<Label
					text="{i18n>bugdetails}"
					required="{RaiseBugModel>/Submit}"
				/>
				<TextArea
					editable="{VisibleModel>/Editable}"
					id="RB_id_bugDescription"
					rows="4"
					liveChange="onBugdescriptionchnages"
					valueStateText="{i18n>companyInvoiceDescPlaceH}"
					placeholder="{i18n>ENTER_BUG_DESCRIPTION}"
					value="{RaiseBugModel>/BugDescription}"
					maxLength="200"
				/>
				<!-- Raised By -->
				<Label text="{i18n>raisedby}" />
				<Input
					id="RB_id_RaisedBy"
					liveChange="onBugRaisedby"
					valueStateText="{i18n>enteryourname}"
					value="{RaiseBugModel>/RaisedBy}"
					placeholder="{i18n>enteryourname}"
					editable="false"
				/>
				<!-- Email -->
				<Label
					text="{i18n>contactemail}"
					required="true"
				/>
				<ComboBox
					value="{RaiseBugModel>/EmployeeName}"
					showSecondaryValues="true"
					id="RB_id_Email"
					items="{
						path: 'EmpModel>/'
				
					}"
					filterSecondaryValues="true"
					valueStateText="{i18n>selectassignedto}"
					change="onBugEmailchange"
				>
					<core:ListItem
						key="{EmpModel>EmployeeName}"
						text="{EmpModel>EmployeeName}"
						additionalText="{EmpModel>EmployeeID}"
					/>
				</ComboBox>
				<Label
					text="{i18n>contractStatus}"
					required="true"
				/>
				<ComboBox
					visible="{VisibleModel>/RaiseVisible}"
					id="RB_id_RBStatus"
					valueStateText="{i18n>entercontractstatus}"
					value="{RaiseBugModel>/ContractStatus}"
					change="onAppnamechanges"
					items="{RaiseBug>/}"
				>
					<core:Item
						key="{RaiseBug>RateType}"
						text="{RaiseBug>RateType}"
					/>
				</ComboBox>
				<Label
					text="{i18n>resolvedate}"
					required="true"
				/>
				<DatePicker 
                                id="RB_id_ResolveDate"
								value="{RaiseBugModel>/ResolveDate}"
                                displayFormat="dd/MM/yyyy"
                                valueFormat="dd/MM/yyyy"
                                placeholder="{i18n>selectdate}"
								change="onResolveDateChange"
								valueStateText="{i18n>selectdate}"
								visible="{= ${RaiseBugModel>/ContractStatus} === 'Resolved' ? true : false}"
								 />
				<Label
					text="{i18n>comments}"
					required="true"
					visible="{VisibleModel>/RaiseVisible}"

				/>
				<TextArea
					id="RB_id_comments"
					rows="4"
					liveChange="onBugdescriptionchnages"
					valueStateText="{i18n>entercomments}"
					placeholder="{i18n>entercomments}"
					visible="{VisibleModel>/RaiseVisible}"

					value="{RaiseBugModel>/Comments}"
					maxLength="200"
				/>
				<MessageStrip
					visible="{VisibleModel>/Visible}"
					text=" Image files larger than 2 MB are not allowed."
					type="Warning"
					showIcon="true"
					enableFormattedText="true"
					class="sapUiSmallMarginBottom"
				/>
				<!-- Upload Image (UNCHANGED) -->
				<Label text="{i18n>addImage}" />
				<VBox
					alignItems="Start"
					width="100%"
					renderType="Bare"
					visible="{VisibleModel>/Visible}"
				>
					<!-- Upload Button -->
					<HBox width="100%">
						<u:FileUploader
							id="RB_id_FileUploader1"
							fileSizeExceed="onFileSizeExceed"
							maximumFileSize="2"
							typeMissmatch="onFileTypeMissmatch"
							fileType="jpg,jpeg,png"
							change="onSupportrequestChange"
							buttonOnly="true"
							sameFilenameAllowed="true"
							iconFirst="true"
							buttonText="Upload Images"
							multiple="true"
							uploadOnChange="false"
						/>
					</HBox>
					<!-- Tokens -->
					<Tokenizer
						id="RB_id_TokenList1"
						width="100%"
						class="sapUiSmallMarginTop"
						tokens="{RaiseBugModel>/tokens}"
						tokenDelete="onTokenDelete"
					>
						<Token
							key="{RaiseBugModel>key}"
							text="{RaiseBugModel>text}"
						/>
					</Tokenizer>
				</VBox>
			</f:content>
		</f:SimpleForm>
		<footer>
			<Toolbar>
				<ToolbarSpacer />
				<Button
					visible="{RaiseBugModel>/Submit}"
					text="{i18n>submit}"
					press="onBugSubmit"
				/>
				<Button
					visible="{RaiseBugModel>/Save}"
					text="{i18n>save}"
					press="onPressBugSave"
				/>
				<Button
					text="{i18n>CancelButton}"
					press="RB_onCancelButtonPress"
				/>
			</Toolbar>
		</footer>
	</Dialog>
</c:FragmentDefinition>