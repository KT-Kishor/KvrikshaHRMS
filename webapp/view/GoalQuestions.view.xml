
<mvc:View
    controllerName="sap.kt.com.minihrsolution.controller.GoalQuestions"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:u="sap.ui.unified"
    xmlns:fb="sap.ui.comp.filterbar"
>
    <Page
        id="QD_id_Page"
    >

    <customHeader>
	    <core:Fragment fragmentName="sap.kt.com.minihrsolution.fragment.Header" type="XML" />
		</customHeader>
        <content>

                <Dialog
                    id="QD_id_UploadDialog"
                    title="{i18n>UploadTitle}"
                    draggable="true"
                    resizable="true"
                    contentWidth="400px"
                    contentHeight="auto"
                    class="sapUiResponsivePadding"
                >
                    <content>
                        <VBox class="sapUiSmallMargin">
                            <u:FileUploader
                                id="QD_id_FileUploader"
                                name="myFileUpload"
                                uploadUrl="upload/"
                                width="100%"
                                tooltip="{i18n>UploadTooltip}"
                                uploadComplete="QD_handleUploadComplete"
                                change="QD_handleValueChange"
                                typeMissmatch="QD_handleTypeMissmatch"
                                fileType="xlsx,xls"
                                placeholder="{i18n>ChooseFile}"
                            />
                        </VBox>
                    </content>

                    <beginButton>
                        <Button
                            text="{i18n>upload}"
                            press="QD_handleUploadPress"
                        />
                    </beginButton>

                    <endButton>
                        <Button
                            text="{i18n>cancel}"
                            press="QD_onCloseUploadDialog"
                        />
                    </endButton>
                </Dialog>

                <fb:FilterBar
                    id="QD_id_FilterBar1"
                    search="QD_onGoPress"
                    clear="QD_onClearPress"
                    showRestoreButton="false"
                    showClearOnFB="true"
                    showGoOnFB="true"
                    showFilterConfiguration="false"
                    useToolbar="false"
                    class="sapUiTinyMargin CommonRoundedTable"
                >
                    <fb:filterGroupItems>
                        <fb:FilterGroupItem
                            groupName="Basic"
                            name="Department"
                            label="{i18n>Department}"
                            visibleInFilterBar="true"
                        >
                            <fb:control>
                                <ComboBox
                                    id="QD_id_Department"
                                    width="100%"
                                    placeholder="{i18n>SelectDepartment}"
                                    selectedKey="{viewModel>/selectedDepartment}"
                                    items="{sEmployeeModel>/}"
                                    showClearIcon="true"
                                    selectionChange="QD_onDepartmentFilterChange"
                                    change="QD_onDepartmentFilterChange"
                                >
                                    <core:Item
                                        key="{sEmployeeModel>department}"
                                        text="{sEmployeeModel>department}"
                                    />
                                </ComboBox>
                            </fb:control>
                        </fb:FilterGroupItem>
                    </fb:filterGroupItems>
                </fb:FilterBar>

                <Table
                    id="QD_id_Table"
                    inset="false"
                    mode="MultiSelect"
                    width="auto"
                    growing="true"
                    growingScrollToLoad="true"
                     items="{
        path: 'Questionmodel>/Questions',
        sorter: {
            path: 'Department',
            group: true
        }
    }"
     class="sapUiTinyMargin CommonRoundedTable"
                >
                    <headerToolbar>
                        <OverflowToolbar>
                            <Title
                                id="QD_id_Title"
                                text="{= ${i18n>QuestionsList} + ' (' + (${Questionmodel>/Questions}.length || 0) + ')'}"
                                level="H2"
                            />
                            <ToolbarSpacer />
                            <Button
                               
                                text="{i18n>download}"
                              tooltip="{i18n>downloadTooltip}"
                                
                                press="QD_onDownloadExcelPress"
                            />
                            <Button
                               
                                text="{i18n>upload}"
                                tooltip="{i18n>uploadTooltip}"
                               
                                press="QD_onUploadPress"
                            />

                            <Button
                                text="{i18n>add}"
                             tooltip="{i18n>addTooltip}"
                               
                                press="QD_onCreatePress"
                            />

                            <Button
                                text="{i18n>edit}"
                              tooltip="{i18n>editTooltip}"
                                press="QD_onUpdatePress"
                            />

                            <Button
                                text="{i18n>delete}"
                              tooltip="{i18n>deleteTooltip}"
                            
                                press="QD_onDeletePress"
                            />
                        </OverflowToolbar>
                    </headerToolbar>

                    <columns>
                        <Column
                        width="25%"
                            minScreenWidth="Tablet"
                            demandPopin="true"
                        >
                            <Text text="{i18n>Department}" />
                        </Column>
                        <Column
                        width="25%"
                            minScreenWidth="Tablet"
                            demandPopin="true"
                        >
                            <Text text="{i18n>TopicName}" />
                        </Column>
                        <Column
                        width="50%"
                            minScreenWidth="Phone"
                            demandPopin="true"
                        >
                            <Text text="{i18n>Questions}" />
                        </Column>
                    </columns>

                    <items>
                        <ColumnListItem>
                            <cells>
                                <Text
                                    text="{
                                        path: 'Questionmodel>Department',
                                        formatter: '.formatDepartmentName'
                                    }"
                                />
                                <Text text="{Questionmodel>Topic}" />
                                <Text
                                    text="{Questionmodel>Question}"
                                    wrapping="true"
                                    maxLines="4"
                                />
                            </cells>
                        </ColumnListItem>
                    </items>
                </Table>
        </content>
    </Page>
</mvc:View>