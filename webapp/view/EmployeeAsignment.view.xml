<mvc:View controllerName="sap.kt.com.minihrsolution.controller.EmployeeAsignment"
	xmlns:mvc="sap.ui.core.mvc" 
    displayBlock="true"
	xmlns:fb="sap.ui.comp.filterbar"
	xmlns="sap.m"
	xmlns:core="sap.ui.core">
	<Page showNavButton="true" navButtonPress="AT_onPressback" class="classheader glassHeader ObjectcustomHeaderToolbar" title="{i18n>EmpAssignment}">
    <headerContent>
			<Button press="Tile_NotifictionBTN" class="sapUiTinyMarginBeginEnd LogNot logoutBtn" tooltip="{i18n>TilenotificationfragName}" icon="sap-icon://bell" type="Transparent" visible="{= ${LoginModel>/Role} !== 'Contractor' }">
				<customData >
					<BadgeCustomData class="badgeClass" key="badge" value="{EndingSoonModel>/notificationCount}"/>
				</customData>
			</Button>
			 <Button
            press="TP_onraisebugpress"
            icon="sap-icon://incident"
            tooltip="{i18n>raisebug}"
            type="Transparent"
            class="LogNot logoutBtn"
        />
			<Button press="onLogout" icon="sap-icon://log" tooltip="{i18n>logoutTooltip}"
                type="Transparent" class="LogNot logoutBtn"/>
		</headerContent>
		<!-- <customHeader>
			<core:Fragment fragmentName="sap.kt.com.minihrsolution.fragment.Header" type="XML" />
		</customHeader> -->
		<content>
			<fb:FilterBar  class="sapUiTinyMargin CommonRoundedTable" id="EA_id_FilterBar" persistencyKey="myPersKey" useToolbar="false" clear="MA_onPressClear" showClearOnFB="true" search="EA_onSearch" filterChange=".onFilterChange" afterVariantLoad=".onAfterVariantLoad" showFilterConfiguration="false" >
				<fb:filterGroupItems>
					<fb:FilterGroupItem name="EmployeeName" label="{i18n>employeeName}" groupName="Group1" visibleInFilterBar="true" >
						<fb:control>
							<ComboBox
                                id="EA_id_Employee"
                                showClearIcon="true"
                                items="{path:'EmpDetails>/',length:1000}"
                                showSecondaryValues="true" filterSecondaryValues="true"
                            >
                                <core:ListItem
                                    key="{EmpDetails>EmployeeID}"
                                    text="{EmpDetails>EmployeeName}"
                                    additionalText="{EmpDetails>EmployeeID}"
                                />
                            </ComboBox>
						</fb:control>
					</fb:FilterGroupItem>
					<fb:FilterGroupItem name="StartDate" label="{i18n>assignmentdate}" groupName="Group1" visibleInFilterBar="true">
						<fb:control>
							<DateRangeSelection id="EA_id_StartDate" valueFormat="MM/dd/yyyy"  displayFormat="dd/MM/yyyy"  change=""/>
						</fb:control>
					</fb:FilterGroupItem>
					<fb:FilterGroupItem name="AssignDate" label="Assignment Date" groupName="Group1" visibleInFilterBar="true">
						<fb:control>
							<DatePicker id="EA_id_AssignDate" valueFormat="MM/dd/yyyy"  displayFormat="dd/MM/yyyy"  />
						</fb:control>
					</fb:FilterGroupItem>
				</fb:filterGroupItems>
			</fb:FilterBar>
			<Table class="sapUiTinyMargin CommonRoundedTable" sticky="ColumnHeaders,HeaderToolbar" growingScrollToLoad="true" width="auto" id="EA_id_EmpAssignTable"  items="{AssignmentModel>/}"   alternateRowColors="true">
				<headerToolbar>
					<OverflowToolbar >
						<Title text="Assignment Details ({= ${AssignmentModel>/}.length })"/>
						
					</OverflowToolbar>
				</headerToolbar>
				<columns>
					<Column demandPopin="true" mergeDuplicates="true">
						<Text text="{i18n>employeeOffer}"/>
					</Column>
					<Column demandPopin="true">
						<Text text="{i18n>assignmentName}"/>
					</Column>
					<Column minScreenWidth="Tablet" demandPopin="true">
						<Text text="{i18n>assignmentType}" />
					</Column>
					<Column minScreenWidth="Tablet" demandPopin="true">
						<Text text="{i18n>assignmentDes}" />
					</Column>
					<Column demandPopin="true">
						<Text text="{i18n>startDate}" />
					</Column>
					<Column minScreenWidth="Desktop" demandPopin="true">
						<Text text="{i18n>endDate}" />
					</Column>
				</columns>
				<items>
					<ColumnListItem>
						<cells>
							 <ObjectIdentifier
                                title="{AssignmentModel>EmployeeName}"
                                text="{AssignmentModel>EmployeeID}"
                            />
							<Text text="{AssignmentModel>TaskName}"/>
							<Text text="{AssignmentModel>TaskType}"/>
							<Text text="{AssignmentModel>TaskTypeDescription}"/>
							<Text text="{path:'AssignmentModel>TaskStartDate' ,formatter:'.Formatter.formatDate'}"/>
							<Text text="{path:'AssignmentModel>TaskEndDate' ,formatter:'.Formatter.formatDate'}"/>
						</cells>
					</ColumnListItem>
				</items>
			</Table>
		</content>
		<footer>
			<Bar>
				<contentLeft>
					<core:Fragment fragmentName="sap.kt.com.minihrsolution.fragment.Footer" type="XML" />
				</contentLeft>
			</Bar>
		</footer>
	</Page>
</mvc:View>