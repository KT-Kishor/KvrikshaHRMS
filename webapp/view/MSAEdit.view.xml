<mvc:View
    controllerName="sap.kt.com.minihrsolution.controller.MSAEdit"
    xmlns:mvc="sap.ui.core.mvc"
    displayBlock="true"
    xmlns:f="sap.ui.layout.form"
    xmlns="sap.uxap"
    xmlns:core="sap.ui.core"
    xmlns:layout="sap.ui.layout"
    xmlns:m="sap.m"
>
    <m:Page
        id="MsaE_id_Page"
        title="{i18n>msaDetails}"
        navButtonPress="MsaE_onBack"
        showNavButton="true"
        class="classheader glassHeader ObjectcustomHeaderToolbar"
    >
        <m:headerContent>
            <m:Button
                press="Tile_NotifictionBTN"
                class="sapUiTinyMarginBeginEnd LogNot logoutBtn"
                tooltip="{i18n>TilenotificationfragName}"
                icon="sap-icon://bell"
                type="Transparent"
                visible="{= ${LoginModel>/Role} !== 'Contractor' }"
            >
                <m:customData>
                    <m:BadgeCustomData
                        class="badgeClass"
                        key="badge"
                        value="{EndingSoonModel>/notificationCount}"
                    />
                </m:customData>
            </m:Button>
             <m:Button
            press="TP_onraisebugpress"
            icon="sap-icon://incident"
            tooltip="{i18n>raisebug}"
            type="Transparent"
            class="LogNot logoutBtn"
        />
            <m:Button
                press="onLogout"
                icon="sap-icon://log"
                tooltip="{i18n>logoutTooltip}"
                type="Transparent"
                class="LogNot logoutBtn"
            />
        </m:headerContent>
        <ObjectPageLayout
            busyIndicatorDelay="0"
            enableLazyLoading="true"
            useIconTabBar="true"
            showTitleInHeaderContent="true"
            id="MsaE_id_ObjectPageLayout"
            upperCaseAnchorBar="false"
			
        >
            <headerTitle>
                <ObjectPageDynamicHeaderTitle>
                    <actions>
                        <m:Button
                            id="RenewMSA"
                            text="Renew MSA"
                            type="Transparent"
                            press="MsaE_onEditOrSavePress"
                        />
                        <m:Button
                            id="EditMSA"
                            text="Edit"
                            type="Transparent"
                            press="MsaE_onEditOrSavePress"
                        />
                        <m:Button
                            id="MSA"
                            type="Transparent"
                            text="{i18n>msaSendEmail}"
                            enabled="{simpleForm>/isEnabled}"
                            press="MsaE_onSendEmailMSA"
                        />
                        <m:Button
                            type="Transparent"
                            text="{i18n>GeneratePDF}"
                            enabled="{simpleForm>/isEnabled}"
                            press="MsaE_onPressMerge"
                        />
                    </actions>
                    <expandedHeading>
                        <m:Title
                            text="{FilteredMsaModel>/0/CompanyName}"
                            wrapping="true"
                            class="whiteTitle"
                        />
                    </expandedHeading>
                    <!-- Snapped Header Title (with Avatar + Title) -->
                    <snappedHeading>
                        <m:FlexBox
                            fitContainer="true"
                            alignItems="Center"
                        >
                            <m:Avatar
                                displayShape="Circle"
                                displaySize="M"
                                backgroundColor="Accent1"
                                initials="{= ${FilteredMsaModel>/0/CompanyName} ? ${FilteredMsaModel>/0/CompanyName}.substring(0,2).toUpperCase() : '' }"
                                class="sapUiSmallMarginEnd"
                            />
                            <m:Title
                                text="{FilteredMsaModel>/0/CompanyName}"
                                wrapping="true"
                                class="whiteTitle"
                            />
                        </m:FlexBox>
                    </snappedHeading>
                    <!-- Expanded Content -->
                    <expandedContent>
                        <!-- <m:Text text="{FilteredMsaModel>/0/PanCard}" /> -->
                        <layout:HorizontalLayout class="sapUiTinyMarginTop">
                            <m:Text
                                class="whiteTitle"
                                text="{
								parts: [
								{path: 'FilteredMsaModel>/0/Address'},
								{path: 'FilteredMsaModel>/0/City'},
								{path: 'FilteredMsaModel>/0/Country'}
								],
								formatter: '.Formatter.formatAddress'
							}"
                                wrapping="true"
                            />
                        </layout:HorizontalLayout>
                    </expandedContent>
                    <!-- Snapped Content -->
                    <snappedContent>
                        <layout:VerticalLayout>
                            <layout:HorizontalLayout
                                class="sapUiTinyMarginTop whiteTitle"
                            >
                                <m:Label
                                    text="{i18n>companyHeadName}"
                                    showColon="true"
                                    class="whiteTitle"
                                />
                                <m:Text
                                    class="sapUiTinyMarginBegin whiteTitle"
                                    text="{FilteredMsaModel>/0/Salutation} {FilteredMsaModel>/0/CompanyHeadName}"
                                />
                            </layout:HorizontalLayout>
                            <layout:HorizontalLayout class="sapUiTinyMarginTop">
                                <m:Label
                                    text="{i18n>Address}:"
                                    class="whiteTitle"
                                />
                                <m:Text
                                    class="sapUiTinyMarginBegin whiteTitle"
                                    text="{
									parts: [
									{path: 'FilteredMsaModel>/0/Address'},
									{path: 'FilteredMsaModel>/0/City'},
									{path: 'FilteredMsaModel>/0/Country'}
									],
									formatter: '.Formatter.formatAddress'
								}"
                                    wrapping="true"
                                />
                            </layout:HorizontalLayout>
                        </layout:VerticalLayout>
                    </snappedContent>
                </ObjectPageDynamicHeaderTitle>
            </headerTitle>
            <!-- 4-Column Header Content -->
            <headerContent>
                <m:FlexBox
                    wrap="Wrap"
                    fitContainer="true"
                    alignItems="Start"
                >
                    <!-- Avatar -->
                    <m:Avatar
                        displayShape="Circle"
                        displaySize="L"
                        backgroundColor="Accent1"
                        class="sapUiMediumMarginEnd sapUiTinyMarginBottom sapUiTinyMarginBegin"
                        initials="{= ${FilteredMsaModel>/0/CompanyName} ? ${FilteredMsaModel>/0/CompanyName}.substring(0,2).toUpperCase() : '' }"
                    />

                    <!-- Column 1 -->
                    <layout:VerticalLayout
                        class="sapUiTinyMarginBegin sapUiTinyMarginEnd sapUiTinyMarginBottom"
                    >
                        <layout:HorizontalLayout
                            class="sapUiSmallMarginBeginEnd sapUiTinyMarginBottom"
                        >
                            <m:Label text="{i18n>companyHeadName}:" />
                            <m:Text
                                class="sapUiTinyMarginBegin"
                                text="{FilteredMsaModel>/0/Salutation} {FilteredMsaModel>/0/CompanyHeadName}"
                            />
                        </layout:HorizontalLayout>

                        <layout:HorizontalLayout
                            class="sapUiSmallMarginBeginEnd sapUiTinyMarginBottom"
                        >
                            <m:Label text="{i18n>companyHeadPosition}:" />
                            <m:Text
                                class="sapUiTinyMarginBegin"
                                text="{FilteredMsaModel>/0/CompanyHeadPosition}"
                            />
                        </layout:HorizontalLayout>

                        <layout:HorizontalLayout
                            class="sapUiSmallMarginBeginEnd sapUiTinyMarginBottom"
                        >
                            <m:Label text="{i18n>companyBranch}:" />
                            <m:Text
                                class="sapUiTinyMarginBegin"
                                text="{FilteredMsaModel>/0/CompanyCode}"
                            />
                        </layout:HorizontalLayout>

                        <layout:HorizontalLayout
                            class="sapUiSmallMarginBeginEnd sapUiTinyMarginBottom"
                        >
                            <m:Label text="{i18n>emailId}:" />
                            <m:Text
                                class="sapUiTinyMarginBegin email-wrap-text"
                                text="{FilteredMsaModel>/0/MsaEmail}"
                                wrapping="true"
                                width="100%"
                            />
                        </layout:HorizontalLayout>
                    </layout:VerticalLayout>

                    <!-- Column 2 -->
                    <layout:VerticalLayout
                        class="sapUiTinyMarginBegin sapUiTinyMarginEnd sapUiTinyMarginBottom"
                    >
                        <layout:HorizontalLayout
                            class="sapUiSmallMarginBeginEnd sapUiTinyMarginBottom"
                        >
                            <m:Label text="{i18n>createMSADate}:" />
                            <m:Text
                                class="sapUiTinyMarginBegin"
                                text="{path:'FilteredMsaModel>/0/CreateMSADate', formatter: '.Formatter.formatDate'}"
                            />
                        </layout:HorizontalLayout>

                        <layout:HorizontalLayout
                            class="sapUiSmallMarginBeginEnd sapUiTinyMarginBottom"
                        >
                            <m:Label text="{i18n>msaEndDate}:" />
                            <m:Text
                                class="sapUiTinyMarginBegin"
                                text="{path:'FilteredMsaModel>/0/MsaContractPeriodEndDate', formatter: '.Formatter.formatDate'}"
                            />
                        </layout:HorizontalLayout>

                        <layout:HorizontalLayout
                            class="sapUiSmallMarginBeginEnd sapUiTinyMarginBottom"
                        >
                            <m:Label text="{i18n>paymentterms}:" />
                            <m:Text
                                class="sapUiTinyMarginBegin"
                                text="{FilteredMsaModel>/0/PaymentTerms}"
                            />
                        </layout:HorizontalLayout>

                        <layout:HorizontalLayout
                            class="sapUiSmallMarginBeginEnd sapUiTinyMarginBottom"
                        >
                            <m:Label text="{i18n>type}:" />
                            <m:Text
                                class="sapUiTinyMarginBegin"
                                text="{FilteredMsaModel>/0/Type}"
                            />
                        </layout:HorizontalLayout>
                    </layout:VerticalLayout>

                    <!-- Column 3 -->
                    <layout:VerticalLayout
                        class="sapUiTinyMarginBegin sapUiTinyMarginEnd sapUiTinyMarginBottom"
                    >
                        <layout:HorizontalLayout
                            class="sapUiSmallMarginBeginEnd sapUiTinyMarginBottom"
                        >
                            <m:Label text="{i18n>contractPeriod}:" />
                            <m:Text
                                class="sapUiTinyMarginBegin"
                                text="{FilteredMsaModel>/0/ContractPeriod}"
                            />
                        </layout:HorizontalLayout>

                        <layout:HorizontalLayout
                            class="sapUiSmallMarginBeginEnd sapUiTinyMarginBottom"
                        >
                            <m:Label text="{i18n>panCardCommon}:" />
                            <m:Text visible="{= ${FilteredMsaModel>/0/PanCard} ? true : false }"
                                class="sapUiTinyMarginBegin"
                                text="{FilteredMsaModel>/0/PanCard}"
                            />
                        </layout:HorizontalLayout>

                        <layout:HorizontalLayout
                            class="sapUiSmallMarginBeginEnd sapUiTinyMarginBottom"
                        >
                            <m:Label text="{i18n>GSTNO}:" />
                            <m:Text
                                class="sapUiTinyMarginBegin"
                                text="{FilteredMsaModel>/0/GST}"
                            />
                        </layout:HorizontalLayout>

                        <layout:HorizontalLayout
                            class="sapUiSmallMarginBeginEnd sapUiTinyMarginBottom"
                        >
                            <m:Label text="{i18n>mobileNo}:" />
                            <m:Text
                                class="sapUiTinyMarginBegin"
                                text="{= ${FilteredMsaModel>/0/STDCode} + ' ' + ${FilteredMsaModel>/0/MobileNo} }"
                            />
                        </layout:HorizontalLayout>

                        <!-- Extended Date -->
                        <layout:HorizontalLayout
                            class="sapUiSmallMarginBeginEnd sapUiTinyMarginBottom"
                            visible="{= ${FilteredMsaModel>/0/ExtendedDate} ? true : false }"
                        >
                            <m:Label text="{i18n>MSA_ExtendedDate}:" />
                            <m:Text
                                class="sapUiTinyMarginBegin"
                                text="{path: 'FilteredMsaModel>/0/ExtendedDate', formatter: '.formatter.formatExtendedDates'}"
                            />
                        </layout:HorizontalLayout>
                    </layout:VerticalLayout>
                </m:FlexBox>
            </headerContent>
            <sections>
                <ObjectPageSection
                    titleUppercase="false"
                    title="Sow Details"
                    showTitle="false"
                    id="MsaE_id_SowDetailsSection"
                >
                    <subSections>
                        <ObjectPageSubSection
                            title=" "
                            titleUppercase="false"
                        >
                            <blocks>
                                <m:Table
                                    items="{path:'SowReadModel>/',sorter: {path: 'Description',descending: false,group: true}}"
                                    busyIndicatorDelay="0"
                                    id="Sow_Id_ReadTable"
                                    mode="SingleSelectLeft"
                                    selectionChange="onPressChangeSow"
                                    sticky="ColumnHeaders,HeaderToolbar"
                                    class="sapUiTinyMargin CommonRoundedTable"
                                >
                                    <m:headerToolbar>
                                        <m:OverflowToolbar>
                                            <m:Title
                                                text="{i18n>sowTitle} ({= ${SowReadModel>/}.length })"
                                            />
                                            <m:ToolbarSpacer />
                                            <m:ComboBox
                                                id="MsaE_id_SowStatus"
                                                items="{SowStatusModel>/SowStatus}"
                                                width="10%"
                                                change="MsaE_onChangeSowStatus"
                                            >
                                                <core:Item
                                                    key="{SowStatusModel>ID}"
                                                    text="{SowStatusModel>Status}"
                                                />
                                            </m:ComboBox>
                                            <m:ToolbarSeparator />
                                            <m:Button
                                                text="{i18n>addSOW}"
                                                type="Transparent"
                                                press="MsaE_onPressCreateSow"
                                            />
                                            <m:ToolbarSeparator />
                                            <m:Button
                                                icon="sap-icon://action"
                                                text="Actions"
                                                press="onOpenActionSheet"
                                            />
                                        </m:OverflowToolbar>
                                    </m:headerToolbar>
                                    <m:columns>
                                        <m:Column demandPopin="true">
                                            <m:Text
                                                text="{i18n>POConsultantname}"
                                            />
                                        </m:Column>
                                        <m:Column
                                            minScreenWidth="Desktop"
                                            demandPopin="true"
                                        >
                                            <m:Text text="{i18n>startDate}" />
                                        </m:Column>
                                        <m:Column
                                            minScreenWidth="Tablet"
                                            demandPopin="true"
                                        >
                                            <m:Text text="{i18n>endDate}" />
                                        </m:Column>
                                        <m:Column
                                            minScreenWidth="Tablet"
                                            demandPopin="true"
                                        >
                                            <m:Text text="{i18n>designation}" />
                                        </m:Column>
                                        <m:Column
                                            minScreenWidth="Tablet"
                                            demandPopin="true"
                                        >
                                            <m:Text text="{i18n>rate}" />
                                        </m:Column>
                                        <m:Column
                                            minScreenWidth="Tablet"
                                            demandPopin="true"
                                        >
                                            <m:Text text="{i18n>status}" />
                                        </m:Column>
                                    </m:columns>
                                    <m:items>
                                        <m:ColumnListItem>
                                            <m:cells>
                                                <m:Text
                                                    text="{SowReadModel>ConsultantName}"
                                                />
                                                <m:Text
                                                    text="{path:'SowReadModel>StartDate',formatter: '.Formatter.formatDate'}"
                                                />
                                                <m:Text
                                                    text="{path:'SowReadModel>EndDate',formatter: '.Formatter.formatDate'}"
                                                />
                                                <m:Text
                                                    text="{SowReadModel>Designation}"
                                                />
                                                <m:Text
                                                    text="{SowReadModel>Rate}"
                                                />
                                                <m:ObjectStatus
                                                    text="{SowReadModel>Status}"
                                                    inverted="false"
                                                    state="{path: 'SowReadModel>Status', formatter: '.Formatter.formatObjectStatus'}"
                                                />
                                            </m:cells>
                                        </m:ColumnListItem>
                                    </m:items>
                                </m:Table>
                            </blocks>
                        </ObjectPageSubSection>
                    </subSections>
                </ObjectPageSection>
            </sections>
        </ObjectPageLayout>
    </m:Page>
</mvc:View>

