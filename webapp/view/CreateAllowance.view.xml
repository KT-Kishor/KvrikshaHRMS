<mvc:View controllerName="sap.kt.com.minihrsolution.controller.CreateAllowance"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns="sap.m"
	xmlns:c="sap.ui.core"
    displayBlock="true"
    height="100%"
    busyIndicatorDelay="0"
	xmlns:core="sap.ui.core"
	xmlns:fb="sap.ui.comp.filterbar">
	<Page showHeader="true">
		<customHeader>
			<core:Fragment fragmentName="sap.kt.com.minihrsolution.fragment.Header" type="XML"/>
		</customHeader>
		<content>
			<fb:FilterBar id="CA_id_Filterbar" persistencyKey="myPersKey" useToolbar="false" clear="CA_onPressClear" showClearOnFB="true" search="onSearch" filterChange="IA_.onFilterChange" afterVariantLoad="IA_.onAfterVariantLoad" showFilterConfiguration="false" class="filterBarTheme sapUiTinyMargin CommonRoundedTable">
				<fb:filterGroupItems>
					<fb:FilterGroupItem name="allowanceName" label="{i18n>allowanceName}" groupName="Group" visibleInFilterBar="true">
						<fb:control>
							<ComboBox id="CA_id_Allowancename" items="{AllowanceDropdownModel>/}" showClearIcon="true" showSecondaryValues="true">
								<core:ListItem key="{AllowanceDropdownModel>AllowanceType}" text="{AllowanceDropdownModel>AllowanceType}"/>
							</ComboBox>
						</fb:control>
					</fb:FilterGroupItem>
				</fb:filterGroupItems>
			</fb:FilterBar>
			<Table id="CA_idTable" sticky="ColumnHeaders,HeaderToolbar" mode="SingleSelectLeft" width="auto" busyIndicatorDelay="0" class="sapUiTinyMargin CommonRoundedTable" items="{AllowanceModel>/}" >
				<headerToolbar>
					<OverflowToolbar>
						<Title text="{i18n>allowancerecord} ({= ${AllowanceModel>/}.length})"/>
						<ToolbarSpacer />
						<Button text="{i18n>create}" tooltip="{i18n>resolve}" press="CA_create" class="myUnifiedBtn"/>
						<Button text="{i18n>assestAssignupdate}" tooltip="{i18n>downloadBranchData}" press="onCA_update" class="myUnifiedBtn" />
						<Button text="{i18n>delete}" tooltip="{i18n>downloadBranchData}" press="onCA_delete" class="myUnifiedBtn" />
					</OverflowToolbar>
				</headerToolbar>
				<columns>
					
					<Column demandPopin="true">
						<Text text="{i18n>allowanceName}" tooltip="{i18n>allowanceName}"/>
					</Column>
					<Column demandPopin="true" minScreenWidth="Tablet">
						<Text text="{i18n>allowanceDetails}" tooltip="{i18n>allowanceDetails}"/>
					</Column>
					<Column demandPopin="true" minScreenWidth="Tablet">
						<Text text="{i18n>employeeID}" tooltip="{i18n>employeeID}"/>
					</Column>
					<Column demandPopin="true" minScreenWidth="Tablet">
						<Text text="{i18n>allowanceAmount}" tooltip="{i18n>allowanceAmount}"/>
					</Column>
					
				</columns>
				<items>
					<ColumnListItem>
						<cells>
							<Text text="{AllowanceModel>AllowanceType}" />
							<Text text="{AllowanceModel>AllowanceDescription}" />
							<Text text="{AllowanceModel>EmployeeID}" />
							<Text 
                                  text="{path: 'AllowanceModel>Amount', formatter: '.Formatter.fromatNumber'} {AllowanceModel>Currency}" />
							
						</cells>
					</ColumnListItem>
				</items>
			</Table>
		</content>
		<footer>
            <Bar>
                <contentLeft>
                    <core:Fragment fragmentName="sap.kt.com.minihrsolution.fragment.Footer" type="XML" />
                </contentLeft>
                <contentRight>
                </contentRight>
            </Bar>
        </footer>
	</Page>
</mvc:View>