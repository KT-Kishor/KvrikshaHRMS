<mvc:View
    controllerName="sap.kt.com.minihrsolution.controller.AllowanceApplication"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns="sap.m"
	xmlns:core="sap.ui.core"
	xmlns:fb="sap.ui.comp.filterbar"
    displayBlock="true"
    height="100%"
    busyIndicatorDelay="0">
	<Page>
		<customHeader>
			<core:Fragment fragmentName="sap.kt.com.minihrsolution.fragment.Header" type="XML" />
		</customHeader>
		<content>
			<fb:FilterBar
                id="All_id_FilterBar"
                showFilterConfiguration="false"
                persistencyKey="myPersKey"
                useToolbar="false"
                clear="Exp_onPressClear"
                showClearOnFB="true"
                search="Exp_onSearch"
                filterChange=".onFilterChange"
                afterVariantLoad=".onAfterVariantLoad"
                class="sapUiTinyMargin CommonRoundedTable">
				<fb:filterGroupItems>
					<!-- Employee (Admin only) -->
					<fb:FilterGroupItem
                        name="EmployeeID"
                        label="{i18n>employeeID}"
                        groupName="Group1"
                        visibleInFilterBar="{= ${LoginModel>/Role} === 'Admin' }">
						<fb:control>
							<ComboBox
                                id="All_id_EmployeeName"
                                name="EmployeeID"
                                change="onChangeEmployeeID"
                                showSecondaryValues="true"
                                filterSecondaryValues="true"
                                showClearIcon="true"
                                items="{ManagerModel>/}">
								<core:ListItem
                                    key="{ManagerModel>EmployeeID}"
                                    text="{ManagerModel>EmployeeID}"
                                    additionalText="{ManagerModel>EmployeeName}" />
							</ComboBox>
						</fb:control>
					</fb:FilterGroupItem>
					<!-- Status -->
					<fb:FilterGroupItem
                        name="Status"
                        label="{i18n>status}"
                        groupName="Group1"
                        visibleInFilterBar="true">
						<fb:control>
							<ComboBox
                                id="All_id_StatusFilter"
                                name="Status"
                                showClearIcon="true"
                                items="{Allowance>/}">
								<core:Item
                                    key="{Allowance>StatusName}"
                                    text="{Allowance>StatusName}" />
							</ComboBox>
						</fb:control>
					</fb:FilterGroupItem>
					<!-- Date Range -->
					<fb:FilterGroupItem
                        name="AllowanceDate"
                        label="{i18n>DetAllowanceDate}"
                        groupName="Group1"
                        visibleInFilterBar="true">
						<fb:control>
							<DateRangeSelection
                                id="All_id_InvoiceDatePicker"
                                valueFormat="yyyy-MM-dd"
                                displayFormat="dd/MM/yyyy"
                                change="onDateRangeChange" />
						</fb:control>
					</fb:FilterGroupItem>
				</fb:filterGroupItems>
			</fb:FilterBar>
			<!-- Table -->
			<Table
                id="All_id_Expense"
                items="{
                    path: 'AllowanceModel>/',
                    sorter: { path: 'Status', descending: false, group: true },
                    groupHeaderFactory: '.getGroupHeader'
                }"
                class="sapUiTinyMargin CommonRoundedTable"
                growing="true"
                growingThreshold="50"
                growingScrollToLoad="true"
                alternateRowColors="true"
                width="auto"
                mode="SingleSelectLeft"
                selectionChange="onTableSelectionChange"
                sticky="ColumnHeaders,HeaderToolbar"
                busyIndicatorDelay="0">
				<headerToolbar>
					<OverflowToolbar>
						<Title
                            id="All_id_title"
                            text="{i18n>allowanceDetails} ({= ${AllowanceModel>/}.length })" />
						<ToolbarSpacer/>
						<Button
                            id="All_id_DeleteBtn"
                            type="Transparent"
                            enabled="false"
                            text="{i18n>deleteallowance}"
                            press="Exp_onPressDeleteExpense" />
						<Button
                            type="Transparent"
                            text="{i18n>applyallowance}"
                            press="Exp_onPressAddExpense" />
					</OverflowToolbar>
				</headerToolbar>
				<columns>
					<Column>
						<Label text="{i18n>employeeName}" class="whiteLabel" />
					</Column>
					<Column>
						<Label text="{i18n>allowanceType}" class="whiteLabel" />
					</Column>
					<Column minScreenWidth="Desktop">
						<Label text="{i18n>startDate}" class="whiteLabel" />
					</Column>
					<Column minScreenWidth="Desktop">
						<Label text="{i18n>endDate}" class="whiteLabel" />
					</Column>
					<Column minScreenWidth="Desktop">
						<Label text="{i18n>totalAmount}" class="whiteLabel" />
					</Column>
				</columns>
				<items>
					<ColumnListItem type="Navigation" press="Exp_onCheckExpenseDetails">
						<cells>
							<ObjectIdentifier title="{AllowanceModel>EmployeeName}" text="{AllowanceModel>EmployeeID}" />
							<Text text="{AllowanceModel>AllowanceType}" />
							<Text text="{path:'AllowanceModel>AllowanceStartDate', formatter: '.Formatter.formatDate'}" />
							<Text text="{path:'AllowanceModel>AllowanceEndDate', formatter: '.Formatter.formatDate'}" />
							<Text text="INR {path:'AllowanceModel>TotalAmount', formatter: '.Formatter.fromatNumber'}" />
						</cells>
					</ColumnListItem>
				</items>
			</Table>
		</content>
		<footer>
			<Bar>
				<contentLeft>
					<core:Fragment fragmentName="sap.kt.com.minihrsolution.fragment.Footer" type="XML" />
				</contentLeft>
			</Bar>
		</footer>
	</Page>
</mvc:View>